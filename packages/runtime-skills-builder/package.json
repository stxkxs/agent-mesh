{
  "name": "@agent-mesh/runtime-skills-builder",
  "version": "0.0.0",
  "type": "module",
  "description": "Skill bundle packer + manifest validator. Produces deterministic .tar.gz + SHA-256 fingerprint + Zod-validated manifest.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/stxkxs/agent-mesh.git",
    "directory": "packages/runtime-skills-builder"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@agent-mesh/core": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@agent-mesh/config": "workspace:*",
    "@types/node": "^25.7.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
