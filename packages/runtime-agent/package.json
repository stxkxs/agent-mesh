{
  "name": "@agent-mesh/runtime-agent",
  "version": "0.0.0",
  "type": "module",
  "description": "Agent loop: defineAgent + defineTool + runAgent. Drives a ProviderAdapter through tool dispatch + Zod-validated structured output, with prompt-resolver pulling versioned prompts from Blob via App Configuration pointers.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/stxkxs/agent-mesh.git",
    "directory": "packages/runtime-agent"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./define-agent": {
      "types": "./dist/define-agent.d.ts",
      "import": "./dist/define-agent.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "import": "./dist/tools.js"
    },
    "./circuit-breaker": {
      "types": "./dist/circuit-breaker.d.ts",
      "import": "./dist/circuit-breaker.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@agent-mesh/core": "workspace:*",
    "@agent-mesh/sdk": "workspace:*",
    "@azure/app-configuration": "^1.11.0",
    "@azure/identity": "^4.13.1",
    "@azure/storage-blob": "^12.31.0",
    "@opentelemetry/api": "^1.9.1",
    "opossum": "^9.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@agent-mesh/config": "workspace:*",
    "@types/node": "^25.7.0",
    "@types/opossum": "^8.1.9"
  },
  "peerDependencies": {
    "typescript": "^6.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
